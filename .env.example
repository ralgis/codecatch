# ─────────────────────────────────────────────────────────────────────────────
# codecatch — environment variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in real values. Never commit `.env`.

# ─── Database ────────────────────────────────────────────────────────────────
# Connection string used by api + workers. When running via docker-compose,
# host = postgres (compose service name); when running locally outside docker,
# host = localhost.
DATABASE_URL=postgres://codecatch:CHANGE_ME@postgres:5432/codecatch

# Used by docker-compose to provision the postgres container on first start.
POSTGRES_USER=codecatch
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=codecatch

# ─── Cryptography ────────────────────────────────────────────────────────────
# SECRET_KEY: signs session cookies + various tokens. Generate once:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=CHANGE_ME_to_a_random_string_at_least_48_chars

# ENCRYPTION_KEY: master key for Fernet (encrypts mailbox passwords +
# OAuth refresh tokens). LOSING THIS = LOSING ACCESS TO ALL STORED CREDS.
# Generate once and back up to Bitwarden / 1Password:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=CHANGE_ME_to_a_44_char_fernet_key

# ─── Bootstrap (first run only) ──────────────────────────────────────────────
# On first start codecatch creates one super-admin user from these values,
# then ignores them. To add more admins later, use the admin UI.
BOOTSTRAP_ADMIN_USER=admin
BOOTSTRAP_ADMIN_PASSWORD=CHANGE_ME_strong_password

# ─── Networking ──────────────────────────────────────────────────────────────
# Where the API is exposed. Used for OAuth redirect URI construction.
BASE_URL=http://localhost:8080
HOST=0.0.0.0
PORT=8080

# ─── OAuth client_id strategy ────────────────────────────────────────────────
# 'thunderbird' (default, MVP): use Mozilla Thunderbird's publicly-known
# client_id for Google + Microsoft OAuth. Works out of the box, no Azure or
# Google Cloud setup needed. Grey area legally — fine for self-hosted private
# use, not for commercial SaaS.
#
# 'self': you've registered your own apps in Azure / Google Cloud and want to
# use those instead. Configure each provider in /admin/providers.
OAUTH_DEFAULT_STRATEGY=thunderbird

# ─── Ops / logging ───────────────────────────────────────────────────────────
LOG_LEVEL=INFO
# Optional Sentry DSN for error tracking:
SENTRY_DSN=

# ─── Misc ────────────────────────────────────────────────────────────────────
# Retention: delete codes older than this many days. Set to 0 to keep forever.
CODE_RETENTION_DAYS=30

# Maximum concurrent IMAP IDLE sessions per worker process.
MAX_IMAP_WORKERS=50

# Playwright settings for headless OAuth (workers container only).
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT_SEC=60
